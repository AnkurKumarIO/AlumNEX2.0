# Backend Environment Variables
PORT=5001

# Frontend URL (for CORS)
FRONTEND_URL=https://insomnia-roan.vercel.app

# Supabase Configuration
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini AI Configuration (optional)
GEMINI_API_KEY=your_gemini_api_key

# Groq AI Configuration — primary AI for all 7 agents
# Free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY_RESUME=your_groq_api_key_for_resume  # optional dedicated key

# Hugging Face Configuration (optional fallback)
HUGGINGFACE_API_KEY=your_huggingface_api_key
HF_MODEL=tiiuae/falcon-7b-instruct

# OpenAI Configuration (optional fallback + OCR)
OPENAI_API_KEY=your_openai_api_key

# JWT Secret — use a long random string in production
JWT_SECRET=your_jwt_secret_key

# TNP Coordinator credentials
TNP_USERNAME=admin
TNP_PASSWORD=your_secure_tnp_password

# TURN Server — get free credentials at https://www.metered.ca
# 1. Sign up at metered.ca
# 2. Create an app (domain = your app name e.g. "alumnex")
# 3. Copy the API Key from dashboard
METERED_APP_NAME=alumnex
METERED_API_KEY=your_metered_api_key
