generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  role                String   @default("STUDENT")
  username            String?  @unique
  password            String?
  name                String
  email               String   @unique
  department          String?
  verification_status String   @default("PENDING")
  profile_data        String?
  google_refresh_token String?

  given_slots         ScheduleSlot[]    @relation("AlumniSlots")
  booked_slots        ScheduleSlot[]    @relation("StudentBookings")
  student_interviews  InterviewRecord[] @relation("StudentInterviews")
  alumni_interviews   InterviewRecord[] @relation("AlumniInterviews")
  
  sent_requests       InterviewRequest[] @relation("StudentRequests")
  received_requests   InterviewRequest[] @relation("AlumniRequests")
  notifications       Notification[]

  student_sessions    SessionFeedback[]  @relation("StudentSessions")
  alumni_sessions     SessionFeedback[]  @relation("AlumniSessions")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model InterviewRequest {
  request_id               String   @id @default(uuid())
  student_id               String
  alumni_id                String
  topic                    String
  message                  String?
  status                   String   @default("PENDING")
  scheduled_time           DateTime?
  room_id                  String?
  student_profile_snapshot String?

  student                  User     @relation("StudentRequests", fields: [student_id], references: [id])
  alumni                   User     @relation("AlumniRequests", fields: [alumni_id], references: [id])

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([student_id])
  @@index([alumni_id])
  @@index([status])
}

model Notification {
  id          String   @id @default(uuid())
  user_id     String
  type        String
  title       String
  message     String
  read        Boolean  @default(false)
  request_id  String?

  user        User     @relation(fields: [user_id], references: [id])

  createdAt   DateTime @default(now())

  @@index([user_id])
  @@index([user_id, read])
}

model ScheduleSlot {
  slot_id    String   @id @default(uuid())
  alumni_id  String
  student_id String?
  start_time DateTime
  end_time   DateTime
  status     String   @default("OPEN")

  alumni     User     @relation("AlumniSlots", fields: [alumni_id], references: [id])
  student    User?    @relation("StudentBookings", fields: [student_id], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InterviewRecord {
  interview_id    String   @id @default(uuid())
  student_id      String
  alumni_id       String
  transcript      String?
  student_score   Float?
  alumni_feedback String?
  ai_action_items String?

  student         User     @relation("StudentInterviews", fields: [student_id], references: [id])
  alumni          User     @relation("AlumniInterviews", fields: [alumni_id], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([student_id])
  @@index([alumni_id])
}

model SessionFeedback {
  id              String   @id @default(uuid())
  room_id         String   @unique
  topic           String?
  meet_link       String?

  student_id      String
  alumni_id       String
  student_name    String?
  alumni_name     String?

  student_rating   Int?
  student_feedback String?
  alumni_rating    Int?
  alumni_feedback  String?

  duration_minutes Int?
  status           String   @default("COMPLETED")

  student         User     @relation("StudentSessions", fields: [student_id], references: [id])
  alumni          User     @relation("AlumniSessions", fields: [alumni_id], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  icon      String
  color     String
  title     String
  desc      String
  category  String   @default("general")
  createdAt DateTime @default(now())
}

model PlatformConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
